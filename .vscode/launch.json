{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: RPG (Run Module)",
            "type": "debugpy",
            "request": "launch",
            "module": "projetopy",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Python: RPG (Run File)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/projetopy/__main__.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}

